<%% row_id = [<%= model_model_name.demodulize.underscore %>.provider, <%= model_model_name.demodulize.underscore %>.id].join("_").parameterize(separator: "_") %>
<tr id="model_<%%= row_id %>">
  <td><%%= <%= model_model_name.demodulize.underscore %>.provider_class&.name || <%= model_model_name.demodulize.underscore %>.provider %></td>
  <td><%%= <%= model_model_name.demodulize.underscore %>.name %></td>
  <td><%%= number_with_delimiter(<%= model_model_name.demodulize.underscore %>.context_window) if <%= model_model_name.demodulize.underscore %>.context_window %></td>
  <td>
    <%% input = <%= model_model_name.demodulize.underscore %>.price(:input) %>
    <%% output = <%= model_model_name.demodulize.underscore %>.price(:output) %>
    <%% if input && output %>
      $<%%= "%.2f" % input %> / $<%%= "%.2f" % output %>
    <%% end %>
  </td>
  <td><%%= link_to "Start <%= chat_table_name.singularize.humanize.downcase %>", new_<%= chat_variable_name %>_path(model: <%= model_model_name.demodulize.underscore %>.id) %></td>
</tr>
